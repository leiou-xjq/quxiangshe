# ==========================================
# 理享 (LiXiang) - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# ==========================================

# ---------- 数据库 ----------
MYSQL_PASSWORD=请设置为强密码

# ---------- Redis ----------
REDIS_PASSWORD=

# ---------- JWT ----------
JWT_SECRET=请生成一个至少32位的随机字符串

# ---------- 邮件 (QQ邮箱) ----------
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=您的QQ邮箱@qq.com
MAIL_PASSWORD=您的QQ授权码
MAIL_EXPIRE_SECONDS=300

# ---------- 阿里云 OSS ----------
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_ENABLED=false

# ---------- 豆包 AI 审核 ----------
DOUBAO_API_KEY=
DOUBAO_ENDPOINT=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-lite-32k-250115
REVIEW_ENABLED=true
REVIEW_ASYNC_ENABLED=true
VALUE_REVIEW_ENABLED=true

# ---------- 微信登录 (可选) ----------
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ENABLED=false

# ---------- 短信 (可选) ----------
SMS_MOCK_ENABLED=true

# ---------- FFmpeg ----------
FFMPEG_PATH=/usr/bin/ffmpeg

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ---------- 服务端口 ----------
SERVER_PORT=8080

# ---------- Pusher 实时推送 ----------
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap3