<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quxiangshe.backend.mapper.UserSessionMapper">

    <!-- 根据Token查询会话 -->
    <select id="selectByToken" resultType="com.quxiangshe.backend.entity.UserSession">
        SELECT * FROM user_session 
        WHERE token = #{token} 
        AND status = 1
        AND expires_at > NOW()
        LIMIT 1
    </select>

    <!-- 根据用户ID查询有效会话 -->
    <select id="selectValidSessionsByUserId" resultType="com.quxiangshe.backend.entity.UserSession">
        SELECT * FROM user_session 
        WHERE user_id = #{userId} 
        AND status = 1
        AND expires_at > NOW()
        ORDER BY created_at DESC
    </select>

    <!-- 失效用户所有会话 -->
    <update id="invalidateUserSessions">
        UPDATE user_session 
        SET status = 0, updated_at = NOW()
        WHERE user_id = #{userId} AND status = 1
    </update>

    <!-- 清理过期会话 -->
    <delete id="cleanExpiredSessions">
        DELETE FROM user_session 
        WHERE expires_at &lt; #{now}
    </delete>

</mapper>